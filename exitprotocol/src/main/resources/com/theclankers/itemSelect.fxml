<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.shape.Rectangle?>
<?import javafx.scene.text.Font?>

<GridPane styleClass="questionbackground" stylesheets="@css/questiontemplate.css"
   xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1"
   fx:controller="com.theclankers.ItemSelectController">
   <columnConstraints>
      <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" />
   </columnConstraints>
   <rowConstraints>
      <RowConstraints minHeight="10.0" vgrow="SOMETIMES" />
   </rowConstraints>
   <children>
      <AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
         minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" GridPane.halignment="CENTER"
         GridPane.hgrow="ALWAYS" GridPane.valignment="CENTER" GridPane.vgrow="ALWAYS">
         <children>
            <Rectangle arcHeight="5.0" arcWidth="5.0" height="410.0" layoutX="-10.0" layoutY="-20.0"
               opacity="0.53" stroke="BLACK" strokeType="INSIDE" width="621.0" />
            <Rectangle arcHeight="40.0" arcWidth="40.0" fill="#d9d8d8" height="247.0"
               layoutX="116.0" layoutY="80.0" opacity="0.67" stroke="BLACK" strokeType="INSIDE"
               width="378.0" />
            <Button fx:id="item1" layoutX="177.0" layoutY="158.0" mnemonicParsing="false"
               text="Item1" visible="false">
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
               <font>
                  <Font size="18.0" />
               </font>
            </Button>
            <Button fx:id="item2" layoutX="377.0" layoutY="150.0" mnemonicParsing="false"
               text="Item 2" visible="false">
               <font>
                  <Font size="18.0" />
               </font>
            </Button>
            <Button fx:id="item3" layoutX="282.0" layoutY="237.0" mnemonicParsing="false"
               text="Item 3" visible="false">
               <font>
                  <Font size="18.0" />
               </font>
            </Button>
            <Button fx:id="backButton" layoutX="43.0" layoutY="350.0" mnemonicParsing="false"
               onMouseClicked="#backToGameBtn" text="Back">
               <font>
                  <Font size="18.0" />
               </font>
            </Button>
         </children>
      </AnchorPane>
   </children>
</GridPane>